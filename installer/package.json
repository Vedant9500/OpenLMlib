{
  "name": "openlmlib",
  "version": "0.1.4",
  "description": "AI-powered knowledge library for LLM agents — install, manage, and retrieve findings via CLI and MCP",
  "type": "module",
  "main": "src/cli.js",
  "bin": {
    "openlmlib": "bin/openlmlib.js"
  },
  "preferGlobal": true,
  "scripts": {
    "postinstall": "node src/postinstall.mjs",
    "dev": "node src/cli.js",
    "build": "echo 'No build step — src runs directly with Node.js'"
  },
  "keywords": [
    "ai",
    "llm",
    "knowledge-base",
    "mcp",
    "retrieval",
    "embeddings",
    "rag",
    "cli"
  ],
  "author": "OpenLMlib Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vedant9500/OpenLMlib.git"
  },
  "homepage": "https://github.com/Vedant9500/OpenLMlib#readme",
  "bugs": {
    "url": "https://github.com/Vedant9500/OpenLMlib/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ink": "^5.0.0",
    "react": "^18.3.0",
    "ink-select-input": "^6.0.0",
    "ink-text-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "boxen": "^8.0.0",
    "figures": "^6.0.0"
  }
}
